{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Atomsyn main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-set-theme",
    "core:window:allow-start-dragging",
    "core:window:allow-theme",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-remove",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "dialog:allow-message",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/atomsyn" },
        { "path": "$APPDATA/atomsyn/**" },
        { "path": "$APPLOCALDATA/atomsyn" },
        { "path": "$APPLOCALDATA/atomsyn/**" },
        { "path": "$LOCALDATA/atomsyn" },
        { "path": "$LOCALDATA/atomsyn/**" },
        { "path": "$HOME/.local/share/atomsyn" },
        { "path": "$HOME/.local/share/atomsyn/**" },
        { "path": "$HOME/Library/Application Support/atomsyn" },
        { "path": "$HOME/Library/Application Support/atomsyn/**" },
        { "path": "$HOME/.claude/skills/**" },
        { "path": "$HOME/.cursor/skills/**" },
        { "path": "$HOME/.atomsyn/**" },
        { "path": "$HOME/.atomsyn-config.json" }
      ]
    }
  ]
}
