{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atomsyn",
  "version": "0.1.1",
  "identifier": "com.atomsyn.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "hiddenTitle": true,
        "theme": "Light",
        "backgroundColor": "#ffffff"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/atomsyn/**",
            "$HOME/Library/Application Support/atomsyn/**",
            "$HOME/.local/share/atomsyn/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi", "nsis"],
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Personal Meta-Skill Vault",
    "longDescription": "Atomsyn — a local-first Personal Meta-Skill Vault for product, UX, and agent-dev methodologies.",
    "resources": [
      "../data/frameworks/**/*",
      "../data/atoms/product-innovation-24/**/*",
      "../data/SEED_VERSION.json",
      "../skills/atomsyn-write/**/*",
      "../skills/atomsyn-read/**/*",
      "../skills/atomsyn-mentor/**/*",
      "../skills/atomsyn-bootstrap/**/*",
      "../scripts/atomsyn-cli.mjs",
      "../scripts/lib/analysis.mjs",
      "../scripts/lib/findRelatedFragments.mjs",
      "../scripts/lib/evolution.mjs",
      "../scripts/lib/bootstrap/**/*",
      "../scripts/bootstrap/prompts/**/*"
    ]
  }
}
